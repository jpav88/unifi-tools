#!/bin/bash
# Local device config — NOT tracked in git
# Copy this to local/devices.sh and fill in your device MACs
# Source this file in scripts/skills that need device-specific MACs or AP mappings

# iPad MACs (Fixed private address per SSID)
IPAD_PRIMARY="xx:xx:xx:xx:xx:xx"
IPAD_SECONDARY="xx:xx:xx:xx:xx:xx"

# AP MAC → friendly name mapping (for skill context)
# Format: MAC|Name|Location
AP_MAP=(
    "xx:xx:xx:xx:xx:xx|AP-Name-1|Location"
    "xx:xx:xx:xx:xx:xx|AP-Name-2|Location"
)

# Format AP_MAP for display
ap_list() {
    for entry in "${AP_MAP[@]}"; do
        IFS='|' read -r mac name loc <<< "$entry"
        echo "- ${name} (\`${mac}\`): ${loc}"
    done
}
